CVE-2019-10743 until=2021-10-17

# DoS in github.com/buger/jsonparser Delete() on malformed input (CVSS 7.5).
# Reached transitively: mcp-go -> invopop/jsonschema -> wk8/go-ordered-map -> jsonparser.
# We never call jsonparser.Delete and our JSON input is not attacker-controlled on that path.
# Revisit once a patched jsonparser release is available upstream.
CVE-2026-32285 until=2026-10-20
